<Window x:Class="VSIXProject1.Localization.LanguageSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:VSIXProject1.Localization"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        Title="{Binding [Dialog_LanguageTitle], Source={x:Static loc:TranslationProvider.Instance}}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText"
                   Text="{Binding [Dialog_SelectLanguage], Source={x:Static loc:TranslationProvider.Instance}}"
                   Grid.Row="0"
                   Margin="0,0,0,8"/>

        <ComboBox x:Name="LanguageComboBox"
                  Grid.Row="1"
                  MinWidth="220"
                  DisplayMemberPath="DisplayName"
                  SelectedValuePath="Language"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="OkButton"
                    Content="{Binding [Button_OK], Source={x:Static loc:TranslationProvider.Instance}}"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="OkButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="{Binding [Button_Cancel], Source={x:Static loc:TranslationProvider.Instance}}"
                    Width="80"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
