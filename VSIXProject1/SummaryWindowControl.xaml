<UserControl x:Class="VSIXProject1.SummaryWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:loc="clr-namespace:VSIXProject1.Localization"
             Background="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
             Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}">
    <Grid>
        <!-- 标题栏 -->
        <Grid Background="{DynamicResource {x:Static vs:EnvironmentColors.CommandBarMenuBackgroundGradientBrushKey}}" Height="28">
            <TextBlock Text="{Binding [ToolWindow_Title], Source={x:Static loc:TranslationProvider.Instance}}" FontSize="12" FontWeight="Medium" Margin="8,6,0,0"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
        </Grid>
        
        <!-- 状态栏 -->
        <Grid Background="{DynamicResource {x:Static vs:EnvironmentColors.CommandBarGradientBrushKey}}" Height="24" Margin="0,28,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="100"/>
                <ColumnDefinition Width="Auto" MinWidth="150"/>
                <ColumnDefinition Width="Auto" MinWidth="120"/>
                <ColumnDefinition Width="Auto" MinWidth="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="GitStatusText" Grid.Column="0" FontSize="11" Margin="8,4,8,4"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <TextBlock x:Name="BranchText" Grid.Column="1" FontSize="11" Margin="0,4,8,4"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <TextBlock x:Name="ChangedFilesText" Grid.Column="2" FontSize="11" Margin="0,4,8,4"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <TextBlock x:Name="AnalysisModeText" Grid.Column="3" FontSize="11" Margin="0,4,8,4"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <TextBlock x:Name="AnalysisTimeText" Grid.Column="4" FontSize="11" Margin="0,4,8,4"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <ProgressBar x:Name="ProgressBar" Grid.Column="5" Height="16" Margin="8,4,8,4"
                         Visibility="Collapsed" Minimum="0" Maximum="100"/>
            <TextBlock x:Name="ProgressText" Grid.Column="4" FontSize="10" Margin="8,4,8,4"
                       Visibility="Collapsed"
                       Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            <Button x:Name="ToggleModeButton" Grid.Column="5" Content="{Binding [Button_ToggleMode], Source={x:Static loc:TranslationProvider.Instance}}" FontSize="10" Height="20" Margin="0,2,8,2"
                    Background="{DynamicResource {x:Static vs:EnvironmentColors.CommandBarMouseOverBackgroundGradientBrushKey}}"
                    Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"
                    BorderThickness="0" Click="ToggleModeButton_Click"/>
        </Grid>
        
        <!-- 内容区域 -->
        <Grid Margin="0,22,0,0">
            <!-- 问题列表（使用扁平化 ListBox 实现真正的纯平极速虚拟化，大幅缩短 UI 渲染停顿） -->
            <!-- 绑定到 ObservableCollection，结合 VirtualizingStackPanel 实现零延迟渲染 -->
            <ListBox x:Name="DiagnosticsTree" Margin="0,0,0,0"
                     Background="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowBackgroundBrushKey}}"
                     BorderThickness="0"
                     MouseDoubleClick="DiagnosticsTree_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ScrollViewer.CanContentScroll="True">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- 使用 Margin 伪造树状缩进。当 IsHeader 为 True 时靠左加粗显示文件名，否则缩进显示具体错误 -->
                        <TextBlock Text="{Binding DisplayText}" 
                                   Margin="{Binding IndentMargin}"
                                   FontWeight="{Binding TextWeight}"
                                   Foreground="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel IsVirtualizing="True"
                                                VirtualizationMode="Recycling"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                     Color="{DynamicResource {x:Static vs:TreeViewColors.SelectedItemActiveColorKey}}"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                     Color="{DynamicResource {x:Static vs:TreeViewColors.SelectedItemActiveTextColorKey}}"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"
                                     Color="{DynamicResource {x:Static vs:TreeViewColors.SelectedItemInactiveColorKey}}"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}"
                                     Color="{DynamicResource {x:Static vs:TreeViewColors.SelectedItemInactiveTextColorKey}}"/>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource {x:Static vs:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                        <Setter Property="Padding" Value="2,2,2,2"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Resources>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
